# Production Environment Variables for Backend
# Copy this file to .env and fill in the values

NODE_ENV=production
PORT=5000

# MongoDB Atlas Connection String
# Get this from MongoDB Atlas dashboard
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/thalai-guardian?retryWrites=true&w=majority

# JWT Secret - Generate a secure random string
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_secure_jwt_secret_here

# Logging
LOG_LEVEL=info

# Frontend URL (your Vercel deployment)
FRONTEND_URL=https://your-app.vercel.app

# AI Service URL (your deployed AI service)
AI_SERVICE_URL=https://your-ai-service.onrender.com
